<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="56dp"
        android:paddingBottom="32dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- QR Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬛"
            android:textSize="64sp"
            android:layout_marginBottom="8dp" />

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_title"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- ── Action Cards ────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/cardSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.3">

        <!-- Scan Camera Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanCamera"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="📷  Scan with Camera"
            android:textColor="@color/bg_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_teal"
            app:cornerRadius="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Scan Gallery Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanGallery"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="🖼️  Scan from Gallery"
            android:textColor="@color/accent_teal"
            android:textSize="16sp"
            android:textStyle="bold"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/accent_teal"
            app:strokeWidth="2dp"
            app:cornerRadius="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_color"
            android:layout_marginBottom="16dp" />

        <!-- Generate QR Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerate"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="✨  Generate QR Code"
            android:textColor="@color/accent_purple_light"
            android:textSize="16sp"
            android:textStyle="bold"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/accent_purple"
            app:strokeWidth="2dp"
            app:cornerRadius="16dp"
            android:layout_marginBottom="16dp" />

        <!-- History Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🕘  View History"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>