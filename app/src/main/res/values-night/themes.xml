<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night theme inherits from the same dark theme (already dark) -->
    <style name="Theme.QRScanner" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="colorPrimaryDark">@color/accent_teal_dark</item>
        <item name="colorAccent">@color/accent_teal</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="QRScanner.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/bg_dark</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="navigationIconTint">@color/text_primary</item>
    </style>
</resources>